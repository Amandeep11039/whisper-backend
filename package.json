{
  "name": "whisper-server",
  "version": "1.0.0",
  "description": "Whisper chat backend",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --clean",
    "start": "npx prisma db push && tsx prisma/seed.ts && node dist/server.js",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5",
    "bcrypt": "^5",
    "cookie-parser": "^1",
    "cors": "^2",
    "express": "^4.18",
    "jsonwebtoken": "^9",
    "morgan": "^1",
    "multer": "^1",
    "sharp": "^0.33",
    "socket.io": "^4.7",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5",
    "@types/cookie-parser": "^1",
    "@types/cors": "^2",
    "@types/express": "^4",
    "@types/jsonwebtoken": "^9",
    "@types/morgan": "^1",
    "@types/multer": "^1",
    "@types/node": "^20",
    "prisma": "^5",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5"
  }
}
